# ─────────────────────────────────────────────
# AFAN MARKETING — Variables de entorno
# Copiar este archivo a .env.local y completar
# NO subir .env.local a Git (ya está en .gitignore)
# ─────────────────────────────────────────────

# ── ENTORNO ──
# "development" en rama dev, "production" en rama main
NEXT_PUBLIC_ENV=development

# ── SUPABASE (próxima fase) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── GOOGLE ANALYTICS ──
NEXT_PUBLIC_GA_ID=

# ── SITE URL ──
# dev   → URL preview de Vercel (auto)
# main  → https://afanmarketing.com
NEXT_PUBLIC_SITE_URL=https://afanmarketing.com
